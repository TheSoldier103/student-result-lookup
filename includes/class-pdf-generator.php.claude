<?php
/**
 * Enhanced PDF Generator Class
 * Condensed one-page layout with component breakdown
 */

if (!defined('ABSPATH')) exit;

class SRL_PDF_Generator {
    
    private $logo_path;
    private $watermark_path;
    private $grade_scale;
    
    public function __construct() {
        $plugin_dir = plugin_dir_path(dirname(__FILE__));
        
        // Load TCPDF
        if (file_exists($plugin_dir . 'vendor/autoload.php')) {
            require_once($plugin_dir . 'vendor/autoload.php');
        } elseif (file_exists($plugin_dir . 'vendor/tcpdf/tcpdf.php')) {
            require_once($plugin_dir . 'vendor/tcpdf/tcpdf.php');
        } else {
            wp_die('TCPDF library not found.');
        }
        
        // Set paths
        $this->logo_path = $plugin_dir . 'assets/logo.jpg';
        if (!file_exists($this->logo_path)) {
            $this->logo_path = $plugin_dir . 'assets/logo.png';
        }
        
        $this->watermark_path = $plugin_dir . 'assets/watermark.png';
        if (!file_exists($this->watermark_path)) {
            $this->watermark_path = $plugin_dir . 'assets/watermark.jpg';
        }
        
        // Load grade scale
        $this->grade_scale = include($plugin_dir . 'includes/grade-scale-config.php');
    }
    
    /**
     * Generate PDF report card
     */
    public function generate_report_card($data) {
        $pdf = new TCPDF('P', 'mm', 'A4', true, 'UTF-8', false);
        
        // Set document info
        $pdf->SetCreator('Petra Christian Academy');
        $pdf->SetAuthor('Petra Christian Academy');
        $pdf->SetTitle('Report Card - ' . $data['grades_data']['usergrades'][0]['userfullname']);
        
        // Remove headers/footers
        $pdf->setPrintHeader(false);
        $pdf->setPrintFooter(false);
        
        // Tight margins for one-page layout
        $pdf->SetMargins(10, 10, 10);
        $pdf->SetAutoPageBreak(true, 10);
        
        // Set font - DejaVu Sans
        $pdf->SetFont('dejavusans', '', 8);
        
        // Add page
        $pdf->AddPage();
        
        // Add watermark (behind content)
        if (file_exists($this->watermark_path)) {
            $pdf->SetAlpha(0.05);
            $pdf->Image($this->watermark_path, 35, 90, 140, 0, '', '', '', false, 300, '', false, false, 0, false, false, true);
            $pdf->SetAlpha(1);
        }
        
        // Reset position after watermark
        $pdf->SetY(10);
        
        // Generate HTML
        $html = $this->generate_html($data);
        
        // Write HTML
        $pdf->writeHTML($html, true, false, true, false, '');
        
        // Output
        $filename = $this->generate_filename($data['grades_data']['usergrades'][0]['userfullname']);
        $pdf->Output($filename, 'D');
        exit;
    }
    
    /**
     * Generate HTML content
     */
    private function generate_html($data) {
        $usergrade = $data['grades_data']['usergrades'][0];
        $student_data = $data['student_data'];
        $course_info = $data['course_info'];
        $announcements = $data['announcements'];
        $staff = $data['staff'];
        
        // Organize grade items
        $organized = $this->organize_grade_items($usergrade['gradeitems']);
        
        $html = $this->get_styles();
        
        // Header with logo - COMPACT
        $html .= '<table style="width:100%; border-bottom:2px solid #000; padding-bottom:5px; margin-bottom:8px;"><tr>';
        
        if (file_exists($this->logo_path)) {
            $image_data = base64_encode(file_get_contents($this->logo_path));
            $html .= '<td style="width:18%; vertical-align:middle;">';
            $html .= '<img src="@' . $image_data . '" style="width:50px;" />';
            $html .= '</td>';
        } else {
            $html .= '<td style="width:18%;"></td>';
        }
        
        $html .= '<td style="width:82%; text-align:center; vertical-align:middle;">
            <h1 style="margin:0; font-size:16px; font-weight:bold; color:#000;">PETRA CHRISTIAN ACADEMY</h1>
            <p style="margin:1px 0; font-size:7px; font-style:italic; color:#333;">Righteousness and Excellence</p>
            <p style="margin:1px 0; font-size:6px; color:#333;">Tel: +2348052755971, +2348166777788</p>
            <p style="margin:3px 0 0 0; font-size:9px; font-weight:bold; color:#000;">STUDENT REPORT CARD</p>
        </td></tr></table>';
        
        // Student Information - COMPACT
        $html .= '<table style="width:100%; background:#f5f5f5; border:1px solid #000; margin-bottom:6px; font-size:7px;">
            <tr>
                <td style="width:15%; padding:3px; border-right:1px solid #ccc;"><strong>Name:</strong></td>
                <td style="width:35%; padding:3px; border-right:1px solid #ccc;">' . htmlspecialchars($usergrade['userfullname']) . '</td>
                <td style="width:15%; padding:3px; border-right:1px solid #ccc;"><strong>Class:</strong></td>
                <td style="width:35%; padding:3px;">' . htmlspecialchars($course_info['class']) . '</td>
            </tr>
            <tr>
                <td style="padding:3px; border-right:1px solid #ccc; border-top:1px solid #ccc;"><strong>Sex:</strong></td>
                <td style="padding:3px; border-right:1px solid #ccc; border-top:1px solid #ccc;">' . htmlspecialchars($student_data['sex']) . '</td>
                <td style="padding:3px; border-right:1px solid #ccc; border-top:1px solid #ccc;"><strong>Term:</strong></td>
                <td style="padding:3px; border-top:1px solid #ccc;">' . htmlspecialchars($course_info['term']) . '</td>
            </tr>
            <tr>
                <td style="padding:3px; border-right:1px solid #ccc; border-top:1px solid #ccc;"><strong>Session:</strong></td>
                <td colspan="3" style="padding:3px; border-top:1px solid #ccc;">' . htmlspecialchars($course_info['session']) . '</td>
            </tr>
        </table>';
        
        // Performance Summary with gradient boxes - COMPACT
        if ($organized['course_total']) {
            $total = $organized['course_total'];
            $position = $this->format_position($total['rank']);
            
            $html .= '<h3 style="background:#34495e; color:#fff; padding:4px 6px; margin:6px 0 4px 0; font-size:8px; font-weight:bold;">PERFORMANCE SUMMARY</h3>';
            $html .= '<table style="width:100%; margin-bottom:6px;">
                <tr>
                    <td style="width:25%; padding:8px; background:#667eea; text-align:center; border-radius:3px;">
                        <div style="font-size:6px; color:#fff; opacity:0.9; margin-bottom:2px;">POSITION</div>
                        <div style="font-size:14px; font-weight:bold; color:#fff;">' . $position . '</div>
                        <div style="font-size:8px; color:#fff;">out of ' . $total['numusers'] . '</div>
                    </td>
                    <td style="width:1%;"></td>
                    <td style="width:24%; padding:8px; background:#f093fb; text-align:center; border-radius:3px;">
                        <div style="font-size:6px; color:#fff; opacity:0.9; margin-bottom:2px;">OBTAINED</div>
                        <div style="font-size:14px; font-weight:bold; color:#fff;">' . $total['gradeformatted'] . '</div>
                    </td>
                    <td style="width:1%;"></td>
                    <td style="width:24%; padding:8px; background:#4facfe; text-align:center; border-radius:3px;">
                        <div style="font-size:6px; color:#fff; opacity:0.9; margin-bottom:2px;">OBTAINABLE</div>
                        <div style="font-size:14px; font-weight:bold; color:#fff;">' . $total['grademax'] . '</div>
                    </td>
                    <td style="width:1%;"></td>
                    <td style="width:24%; padding:8px; background:#43e97b; text-align:center; border-radius:3px;">
                        <div style="font-size:6px; color:#fff; opacity:0.9; margin-bottom:2px;">PERCENTAGE</div>
                        <div style="font-size:14px; font-weight:bold; color:#fff;">' . $total['percentageformatted'] . '</div>
                    </td>
                </tr>
            </table>';
        }
        
        // TWO-COLUMN LAYOUT: Attendance | Grade Scale
        $html .= '<table style="width:100%; margin-bottom:6px;"><tr>';
        
        // Column 1: Attendance
        $html .= '<td style="width:49%; vertical-align:top; padding-right:5px;">
            <h3 style="background:#34495e; color:#fff; padding:4px 6px; margin-bottom:4px; font-size:8px; font-weight:bold;">ATTENDANCE</h3>
            <table style="width:100%; border:1px solid #000; font-size:7px;">
                <tr>
                    <td style="width:60%; padding:5px; background:#f5f5f5; border-right:1px solid #ccc; border-bottom:1px solid #ccc;"><strong>Days School Opened:</strong></td>
                    <td style="width:40%; padding:5px; text-align:center; border-bottom:1px solid #ccc;">' . htmlspecialchars($announcements['days_opened'] ?? 'N/A') . '</td>
                </tr>
                <tr>
                    <td style="padding:5px; background:#f5f5f5; border-right:1px solid #ccc;"><strong>Days Present:</strong></td>
                    <td style="padding:5px; text-align:center;">' . htmlspecialchars($organized['attendance']['present'] ?? 'N/A') . '</td>
                </tr>
            </table>
        </td>';
        
        // Column 2: Grade Scale
        $html .= '<td style="width:51%; vertical-align:top;">
            <h3 style="background:#34495e; color:#fff; padding:4px 6px; margin-bottom:4px; font-size:8px; font-weight:bold;">GRADE SCALE</h3>
            <table style="width:100%; border:1px solid #000; font-size:7px;">
                <tr style="background:#ecf0f1;">
                    <th style="padding:4px; text-align:center; border-right:1px solid #ccc; border-bottom:1px solid #ccc; font-weight:bold;">GRADE</th>
                    <th style="padding:4px; text-align:center; border-right:1px solid #ccc; border-bottom:1px solid #ccc; font-weight:bold;">RANGE</th>
                    <th style="padding:4px; text-align:center; border-bottom:1px solid #ccc; font-weight:bold;">REMARK</th>
                </tr>';
        
        foreach ($this->grade_scale as $grade => $info) {
            $html .= '<tr>
                <td style="padding:3px; text-align:center; font-weight:bold; border-right:1px solid #ccc; border-bottom:1px solid #ccc;">' . $grade . '</td>
                <td style="padding:3px; text-align:center; border-right:1px solid #ccc; border-bottom:1px solid #ccc;">' . $info['min'] . '-' . $info['max'] . '</td>
                <td style="padding:3px; text-align:center; font-size:6px; border-bottom:1px solid #ccc;">' . $info['remark'] . '</td>
            </tr>';
        }
        
        $html .= '</table></td></tr></table>';
        
        // Subject Performance - WITH COMPONENTS IN COLUMNS
        if (!empty($organized['subjects'])) {
            $html .= '<h3 style="background:#34495e; color:#fff; padding:4px 6px; margin:6px 0 4px 0; font-size:8px; font-weight:bold;">SUBJECT PERFORMANCE</h3>';
            $html .= '<table style="width:100%; border-collapse:collapse; border:1px solid #000; margin-bottom:6px; font-size:7px;">
                <thead>
                    <tr style="background:#34495e;">
                        <th style="color:#fff; padding:5px 3px; text-align:left; border-right:1px solid #555; font-size:7px;">SUBJECT</th>
                        <th style="color:#fff; padding:5px 3px; text-align:center; border-right:1px solid #555; font-size:6px;">CA<br/>(20)</th>
                        <th style="color:#fff; padding:5px 3px; text-align:center; border-right:1px solid #555; font-size:6px;">1ST EXAM<br/>(30)</th>
                        <th style="color:#fff; padding:5px 3px; text-align:center; border-right:1px solid #555; font-size:6px;">2ND EXAM<br/>(50)</th>
                        <th style="color:#fff; padding:5px 3px; text-align:center; border-right:1px solid #555; font-size:6px;">TOTAL<br/>(100)</th>
                        <th style="color:#fff; padding:5px 3px; text-align:center; border-right:1px solid #555; font-size:7px;">GRADE</th>
                        <th style="color:#fff; padding:5px 3px; text-align:center; border-right:1px solid #555; font-size:7px;">%</th>
                        <th style="color:#fff; padding:5px 3px; text-align:center; font-size:7px;">POS</th>
                    </tr>
                </thead>
                <tbody>';
            
            $row = 0;
            foreach ($organized['subjects'] as $subject_name => $subject_data) {
                $row++;
                $bg = ($row % 2 == 0) ? '#f9f9f9' : '#ffffff';
                $category = $subject_data['category'];
                $components = $subject_data['components'];
                
                // Extract component scores
                $ca = '-';
                $exam1 = '-';
                $exam2 = '-';
                
                foreach ($components as $comp) {
                    if (stripos($comp['itemname'], 'CA') !== false) {
                        $ca = $comp['gradeformatted'];
                    } elseif (stripos($comp['itemname'], '1st Exam') !== false) {
                        $exam1 = $comp['gradeformatted'];
                    } elseif (stripos($comp['itemname'], '2nd Exam') !== false) {
                        $exam2 = $comp['gradeformatted'];
                    }
                }
                
                $pos = $this->format_position($category['rank']);
                
                $html .= '<tr style="background:' . $bg . ';">
                    <td style="padding:5px 3px; border-bottom:1px solid #ddd; border-right:1px solid #ddd; font-size:7px;">' . htmlspecialchars($subject_name) . '</td>
                    <td style="padding:5px 3px; text-align:center; border-bottom:1px solid #ddd; border-right:1px solid #ddd; font-size:7px;">' . htmlspecialchars($ca) . '</td>
                    <td style="padding:5px 3px; text-align:center; border-bottom:1px solid #ddd; border-right:1px solid #ddd; font-size:7px;">' . htmlspecialchars($exam1) . '</td>
                    <td style="padding:5px 3px; text-align:center; border-bottom:1px solid #ddd; border-right:1px solid #ddd; font-size:7px;">' . htmlspecialchars($exam2) . '</td>
                    <td style="padding:5px 3px; text-align:center; font-weight:bold; border-bottom:1px solid #ddd; border-right:1px solid #ddd; font-size:7px;">' . htmlspecialchars($category['gradeformatted']) . '</td>
                    <td style="padding:5px 3px; text-align:center; font-weight:bold; border-bottom:1px solid #ddd; border-right:1px solid #ddd; font-size:7px;">' . htmlspecialchars($category['lettergradeformatted']) . '</td>
                    <td style="padding:5px 3px; text-align:center; border-bottom:1px solid #ddd; border-right:1px solid #ddd; font-size:7px;">' . htmlspecialchars($category['percentageformatted']) . '</td>
                    <td style="padding:5px 3px; text-align:center; border-bottom:1px solid #ddd; font-size:7px;">' . htmlspecialchars($pos) . '</td>
                </tr>';
            }
            
            $html .= '</tbody></table>';
        }
        
        // Remarks - COMPACT
        $html .= '<h3 style="background:#34495e; color:#fff; padding:4px 6px; margin:6px 0 4px 0; font-size:8px; font-weight:bold;">REMARKS</h3>';
        
        if ($organized['remarks']['teacher']) {
            $html .= '<div style="background:#f5f5f5; padding:6px; margin-bottom:4px; border-left:3px solid #3498db; font-size:7px;">
                <strong>Class Teacher\'s Remark:</strong> ' . strip_tags($organized['remarks']['teacher']) . '<br/>
                <em style="font-size:6px; margin-top:3px; display:block;">Signed by: ' . htmlspecialchars($staff['teacher']) . '</em>
            </div>';
        }
        
        if ($organized['remarks']['principal']) {
            $html .= '<div style="background:#f5f5f5; padding:6px; margin-bottom:4px; border-left:3px solid #e74c3c; font-size:7px;">
                <strong>Principal\'s Remarks:</strong> ' . strip_tags($organized['remarks']['principal']) . '<br/>
                <em style="font-size:6px; margin-top:3px; display:block;">Signed by: ' . htmlspecialchars($staff['principal']) . '</em>
            </div>';
        }
        
        // Announcements - COMPACT
        if (!empty($announcements['next_term']) || !empty($announcements['fees']) || !empty($announcements['general'])) {
            $html .= '<h3 style="background:#34495e; color:#fff; padding:4px 6px; margin:6px 0 4px 0; font-size:8px; font-weight:bold;">ANNOUNCEMENTS</h3>';
            $html .= '<div style="font-size:7px; line-height:1.4;">';
            
            if ($announcements['next_term']) {
                $html .= '<p style="margin:0 0 3px 0;"><strong>Next Term Begins:</strong> ' . htmlspecialchars($announcements['next_term']) . '</p>';
            }
            if ($announcements['fees']) {
                $html .= '<p style="margin:0 0 3px 0;"><strong>Fees for Next Term:</strong> ' . htmlspecialchars($announcements['fees']) . '</p>';
            }
            if ($announcements['general']) {
                $html .= '<p style="margin:0;"><strong>Announcement:</strong> ' . strip_tags($announcements['general']) . '</p>';
            }
            
            $html .= '</div>';
        }
        
        // Footer - COMPACT
        $html .= '<div style="margin-top:8px; padding-top:5px; border-top:1px solid #333; text-align:center; font-size:7px; color:#333;">
            <p style="margin:0;">Petra Christian Academy • Generated on ' . date('F j, Y') . '</p>
        </div>';
        
        return $html;
    }
    
    /**
     * Get PDF styles
     */
    private function get_styles() {
        return '<style>
            body { font-family: dejavusans, sans-serif; font-size: 8px; line-height: 1.3; color: #000; }
            h1 { font-size: 16px; margin: 0; color: #000; }
            h3 { font-size: 8px; margin: 6px 0; background: #34495e; color: #fff; }
            table { border-collapse: collapse; }
            p { margin: 3px 0; }
        </style>';
    }
    
    /**
     * Organize grade items
     */
    private function organize_grade_items($gradeitems) {
        $subjects = [];
        $course_total = null;
        $attendance = ['opened' => null, 'present' => null];
        $remarks = ['teacher' => '', 'principal' => ''];
        
        $categories = [];
        $components_by_category = [];
        
        foreach ($gradeitems as $item) {
            if ($item['itemtype'] === 'course') {
                $course_total = $item;
            } elseif ($item['itemtype'] === 'category') {
                $categories[$item['iteminstance']] = $item;
            } elseif ($item['itemtype'] === 'mod') {
                if (isset($item['categoryid'])) {
                    $components_by_category[$item['categoryid']][] = $item;
                }
            } elseif ($item['itemtype'] === 'manual') {
                if (isset($item['itemname']) && stripos($item['itemname'], 'Days Present') !== false) {
                    $attendance['present'] = $item['gradeformatted'];
                } elseif (isset($item['itemname']) && stripos($item['itemname'], 'Teacher') !== false && stripos($item['itemname'], 'Remark') !== false) {
                    $remarks['teacher'] = $item['feedback'];
                } elseif (isset($item['itemname']) && stripos($item['itemname'], 'Principal') !== false && stripos($item['itemname'], 'Remark') !== false) {
                    $remarks['principal'] = $item['feedback'];
                }
            }
        }
        
        foreach ($categories as $cat_id => $category) {
            $subject_name = $category['itemname'];
            $subjects[$subject_name] = [
                'category' => $category,
                'components' => $components_by_category[$cat_id] ?? []
            ];
        }
        
        return [
            'subjects' => $subjects,
            'course_total' => $course_total,
            'attendance' => $attendance,
            'remarks' => $remarks
        ];
    }
    
    /**
     * Format position (just ordinal, no "out of")
     */
    private function format_position($number) {
        if (!is_numeric($number) || $number <= 0) return 'N/A';
        
        $number = (int)$number;
        $suffix = 'th';
        
        if (!in_array(($number % 100), [11, 12, 13])) {
            switch ($number % 10) {
                case 1: $suffix = 'st'; break;
                case 2: $suffix = 'nd'; break;
                case 3: $suffix = 'rd'; break;
            }
        }
        
        return $number . $suffix;
    }
    
    /**
     * Generate filename
     */
    private function generate_filename($student_name) {
        $clean = preg_replace('/[^A-Za-z0-9_\-]/', '_', $student_name);
        return $clean . '_Report_Card_' . date('Y-m-d') . '.pdf';
    }
}
